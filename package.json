{
  "name": "bestbill-desktop",
  "version": "1.0.0",
  "description": "BestBill POS Offline Desktop Application",
  "main": "electron/main.js",
  "scripts": {
    "postinstall": "cd backend && npm install && cd ../frontend && npm install",
    "electron-dev": "concurrently --kill-others \"npm run start --prefix backend\" \"npm run dev --prefix frontend\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "dist": "npm run build --prefix frontend && electron-builder"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.3.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "qrcode": "^1.5.3",
    "socket.io": "^4.8.3"
  },
  "keywords": [],
  "author": "BestBill",
  "license": "ISC",
  "build": {
    "appId": "com.bestbill.pos",
    "productName": "BestBill",
    "win": {
      "target": "nsis",
      "icon": "frontend/public/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BestBill POS"
    },
    "files": [
      "electron/**/*",
      "backend/**/*",
      "frontend/dist/**/*",
      "!backend/node_modules/**/*",
      "!backend/bestbill.db",
      "!backend/uploads/**/*",
      "!backend/backups/**/*"
    ]
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^34.0.0",
    "electron-builder": "^24.9.1",
    "wait-on": "^7.2.0"
  }
}
